rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Helper ────────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ── User files — owner only, 5 MB cap ─────────────────────────────────────

    match /users/{uid}/{allPaths=**} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid) &&
                      request.resource.size < 5 * 1024 * 1024;
    }

    // ── Company files — members only, 50 MB cap ───────────────────────────────

    match /companies/{companyId}/{allPaths=**} {
      allow read: if isAuth() &&
        firestore.exists(/databases/(default)/documents/companies/$(companyId)/members/$(request.auth.uid));
      allow write: if isAuth() &&
        firestore.exists(/databases/(default)/documents/companies/$(companyId)/members/$(request.auth.uid)) &&
        request.resource.size < 50 * 1024 * 1024;
    }

    // ── Task attachments (global tasks) — owner only, 20 MB cap ──────────────

    match /globalTasks/{uid}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isOwner(uid) &&
                      request.resource.size < 20 * 1024 * 1024;
    }

    // ── Task file uploads — any authenticated user, 20 MB cap ──────────────

    match /tasks/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth() &&
                      request.resource.size < 20 * 1024 * 1024;
    }
  }
}
