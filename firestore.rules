rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isCompanyMember(companyId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid));
    }

    function getMemberData(companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid)).data;
    }

    function isCompanyAdmin(companyId) {
      return isAuth() &&
        getMemberData(companyId).role in ['admin', 'master_admin', 'owner'];
    }

    function isMasterAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'master_admin';
    }

    function isSessionHost(sessionId) {
      return isAuth() &&
        get(/databases/$(database)/documents/screenSessions/$(sessionId)).data.hostUserId == request.auth.uid;
    }

    // ── Users ─────────────────────────────────────────────────────────────────

    match /users/{userId} {
      // Signed-in users can read public profiles; only owner can write own doc
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == userId;

      match /settings/{settingId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }

      match /integrations/{integrationId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }
    }

    // ── Companies ─────────────────────────────────────────────────────────────

    match /companies/{companyId} {
      allow read: if isCompanyMember(companyId) || isMasterAdmin() ||
                     (isAuth() && request.auth.token.email in resource.data.accessList);
      allow create: if isAuth();
      allow update: if isCompanyAdmin(companyId) || isMasterAdmin();
      allow delete: if isMasterAdmin();

      // Members — only admins/owners can delete or remove members
      match /members/{memberId} {
        allow read: if isCompanyMember(companyId) || isMasterAdmin() || request.auth.uid == memberId;
        allow create, update: if isCompanyAdmin(companyId) || isMasterAdmin() ||
                                 get(/databases/$(database)/documents/companies/$(companyId)).data.owner == request.auth.uid;
        allow delete: if isCompanyAdmin(companyId) || isMasterAdmin();
      }

      // Projects
      match /projects/{projectId} {
        allow read: if isCompanyMember(companyId);
        allow create, update: if isCompanyMember(companyId);
        allow delete: if isCompanyAdmin(companyId) ||
                         resource.data.createdBy == request.auth.uid ||
                         isMasterAdmin();

        match /tasks/{taskId} {
          allow read, write: if isCompanyMember(companyId);
        }

        match /tasks/{taskId}/comments/{commentId} {
          allow read: if isCompanyMember(companyId);
          allow create: if isCompanyMember(companyId);
          allow update, delete: if isCompanyMember(companyId) &&
                                   resource.data.authorId == request.auth.uid;
        }

        match /comments/{commentId} {
          allow read: if isCompanyMember(companyId);
          allow create: if isCompanyMember(companyId);
          allow update, delete: if isCompanyMember(companyId) &&
                                   resource.data.authorId == request.auth.uid;
        }

        match /files/{fileId} {
          allow read, write: if isCompanyMember(companyId);
        }

        match /chat/{messageId} {
          allow read: if isCompanyMember(companyId);
          allow create: if isCompanyMember(companyId);
          allow update, delete: if isCompanyMember(companyId) &&
                                   resource.data.senderId == request.auth.uid;
        }
      }

      // Company-wide tasks
      match /tasks/{taskId} {
        allow read, write: if isCompanyMember(companyId);

        match /comments/{commentId} {
          allow read: if isCompanyMember(companyId);
          allow create: if isCompanyMember(companyId);
          allow update, delete: if isCompanyMember(companyId) &&
                                   resource.data.authorId == request.auth.uid;
        }
      }

      // Kanban boards
      match /kanban/{boardId} {
        allow read, write: if isCompanyMember(companyId);
        match /cards/{cardId} {
          allow read, write: if isCompanyMember(companyId);
        }
      }

      match /work/{docId} {
        allow read, write: if isCompanyMember(companyId);
      }

      // Attendance logs
      match /attendance/{recordId} {
        allow read: if isCompanyMember(companyId);
        allow create, update: if isCompanyMember(companyId) &&
                                 request.resource.data.userId == request.auth.uid;
        allow delete: if isCompanyAdmin(companyId);
      }

      // Time logs — written by members for themselves; admins read all
      match /timeLogs/{logId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId) &&
                         request.resource.data.userId == request.auth.uid;
        allow update: if isCompanyMember(companyId) &&
                         resource.data.userId == request.auth.uid;
        allow delete: if isCompanyAdmin(companyId);
      }

      // Group messages (company-level)
      match /messages/{messageId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId);
        allow update, delete: if isCompanyMember(companyId) &&
                                 resource.data.senderId == request.auth.uid;
      }

      match /dashboard/{docId} {
        allow read, write: if isCompanyMember(companyId);
      }

      match /attendanceLogs/{logId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId) &&
                         request.resource.data.userId == request.auth.uid;
        allow update, delete: if isCompanyAdmin(companyId);
      }
    }

    // ── Global chat rooms ──────────────────────────────────────────────────────

    match /chats/{roomId} {
      allow read: if isAuth();

      match /messages/{messageId} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow update, delete: if isAuth() &&
                                 resource.data.senderId == request.auth.uid;
      }
    }

    // ── Screen Sessions ────────────────────────────────────────────────────────

    match /screenSessions/{sessionId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.hostUserId == request.auth.uid;
      allow delete: if isAuth() && resource.data.hostUserId == request.auth.uid;

      match /viewers/{viewerId} {
        allow read: if isAuth();
        // Only the host can write viewer docs (grant/revoke control)
        allow write: if isSessionHost(sessionId) || request.auth.uid == viewerId;

        // canControl field: only writable by host
        // (enforced by the broader write rule above — host-only for most fields)
      }

      match /controlRequests/{requestId} {
        allow read: if isAuth();
        allow create: if isAuth();
        // Only host can update (approve/deny)
        allow update, delete: if isSessionHost(sessionId);
      }
    }

    // ── Personal boards ────────────────────────────────────────────────────────

    match /personalBoards/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
      match /{document=**} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }
    }

    // ── Global tasks ───────────────────────────────────────────────────────────

    match /globalTasks/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
      match /tasks/{taskId} {
        allow read, write: if isAuth() && request.auth.uid == userId;

        match /comments/{commentId} {
          allow read: if isAuth() && request.auth.uid == userId;
          allow create: if isAuth();
          allow update, delete: if isAuth() && resource.data.authorId == request.auth.uid;
        }
      }
    }

    // ── Admin logs ─────────────────────────────────────────────────────────────

    match /adminLogs/{logId} {
      allow read, write: if isMasterAdmin();
    }
  }
}