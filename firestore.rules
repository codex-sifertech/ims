rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isCompanyMember(companyId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid));
    }

    function getMemberData(companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid)).data;
    }

    function isCompanyAdmin(companyId) {
      return isAuth() &&
        getMemberData(companyId).role in ['admin', 'master_admin'];
    }

    function isMasterAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'master_admin';
    }

    // ── Users ─────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == userId;

      // User-scoped settings (attendance toggle, etc.)
      match /settings/{settingId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }
    }

    // ── Companies ─────────────────────────────────────────────────────────────

    match /companies/{companyId} {
      // Allow read if they are a member, an admin, or their email is inherently in the accessList
      allow read: if isCompanyMember(companyId) || isMasterAdmin() || (isAuth() && request.auth.token.email in resource.data.accessList);
      allow create: if isAuth();
      allow update: if isCompanyAdmin(companyId) || isMasterAdmin();
      allow delete: if isMasterAdmin();

      // Members subcollection
      match /members/{memberId} {
        // Members can read the members list, and users can ALWAYS read their own member document (required for App.jsx's check)
        allow read: if isCompanyMember(companyId) || isMasterAdmin() || request.auth.uid == memberId;
        // Admins can write, OR the owner of the company can add users (fixes the chicken-and-egg problem of the first member)
        allow write: if isCompanyAdmin(companyId) || isMasterAdmin() || get(/databases/$(database)/documents/companies/$(companyId)).data.owner == request.auth.uid;
      }

      // Projects
      match /projects/{projectId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId);
        allow update: if isCompanyMember(companyId);
        allow delete: if isCompanyAdmin(companyId) ||
                         resource.data.createdBy == request.auth.uid ||
                         isMasterAdmin();

        // Project tasks (nested under projects)
        match /tasks/{taskId} {
          allow read, write: if isCompanyMember(companyId);
        }

        // Project comments
        match /comments/{commentId} {
          allow read: if isCompanyMember(companyId);
          allow create: if isCompanyMember(companyId);
          allow update, delete: if isCompanyMember(companyId) &&
                                   resource.data.authorId == request.auth.uid;
        }

        // Project files
        match /files/{fileId} {
          allow read: if isCompanyMember(companyId);
          allow write: if isCompanyMember(companyId);
        }
      }

      // Company-wide kanban (WorkBoard)
      match /work/{docId} {
        allow read, write: if isCompanyMember(companyId);
      }

      // Shared kanban boards
      match /kanban/{boardId} {
        allow read, write: if isCompanyMember(companyId);
        match /cards/{cardId} {
          allow read, write: if isCompanyMember(companyId);
        }
      }

      // Attendance & time tracking
      match /attendance/{recordId} {
        allow read: if isCompanyMember(companyId);
        allow create, update: if isCompanyMember(companyId) &&
                                 request.resource.data.userId == request.auth.uid;
        allow delete: if isCompanyAdmin(companyId);

        // Attendance logs subcollection
        match /logs/{logId} {
          allow read: if isCompanyMember(companyId);
          allow create: if isCompanyMember(companyId) &&
                           request.resource.data.userId == request.auth.uid;
          allow delete: if isCompanyAdmin(companyId);
        }
      }

      // Root flattened Attendance Logs
      match /attendanceLogs/{logId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId) &&
                         request.resource.data.userId == request.auth.uid;
        allow update, delete: if isCompanyAdmin(companyId);
      }

      // Group chat messages (company-scoped)
      match /messages/{messageId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId);
        allow update, delete: if isCompanyMember(companyId) &&
                                 resource.data.senderId == request.auth.uid;
      }

      // Dashboard documents (vision board, etc.)
      match /dashboard/{docId} {
        allow read, write: if isCompanyMember(companyId);
      }

      // Company-level tasks
      match /tasks/{taskId} {
        allow read, write: if isCompanyMember(companyId);
      }
    }

    // ── Global chat rooms (company-scoped with room ID) ────────────────────

    match /chats/{roomId} {
      // Room ID is expected to be `company-{companyId}`
      allow read: if isAuth();

      match /messages/{messageId} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow update, delete: if isAuth() &&
                                 resource.data.senderId == request.auth.uid;
      }
    }

    // ── Personal boards ────────────────────────────────────────────────────

    match /personalBoards/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;

      match /{document=**} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }
    }

    // ── Global tasks (company-level collectionGroup) ───────────────────────

    match /globalTasks/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;

      match /tasks/{taskId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }
    }

    // ── Admin-only collections ─────────────────────────────────────────────

    match /adminLogs/{logId} {
      allow read, write: if isMasterAdmin();
    }
  }
}