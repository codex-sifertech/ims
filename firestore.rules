rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if user belongs to the company
    function isCompanyMember(companyId) {
      return isAuth() && exists(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid));
    }

    // Helper: check if user is admin of the company
    function isCompanyAdmin(companyId) {
      return isAuth() && get(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection - users can read/write their own profile
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == userId;
    }

    // Companies collection
    match /companies/{companyId} {
      allow read: if isCompanyMember(companyId);
      allow create: if isAuth();
      allow update, delete: if isCompanyAdmin(companyId);

      // Company members subcollection
      match /members/{memberId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isCompanyAdmin(companyId);
      }

      // Projects - all company members can read, create; only creator/admin can delete
      match /projects/{projectId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId);
        allow update: if isCompanyMember(companyId);
        allow delete: if isCompanyAdmin(companyId) || resource.data.createdBy == request.auth.uid;

        // Project tasks/kanban cards
        match /tasks/{taskId} {
          allow read, write: if isCompanyMember(companyId);
        }

        // Project comments
        match /comments/{commentId} {
          allow read: if isCompanyMember(companyId);
          allow create: if isCompanyMember(companyId);
          allow update, delete: if isCompanyMember(companyId) && resource.data.authorId == request.auth.uid;
        }
      }

      // Shared Kanban boards
      match /kanban/{boardId} {
        allow read, write: if isCompanyMember(companyId);

        match /cards/{cardId} {
          allow read, write: if isCompanyMember(companyId);
        }
      }

      // Group chat messages
      match /messages/{messageId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId);
        allow update, delete: if isCompanyMember(companyId) && resource.data.senderId == request.auth.uid;
      }

      // Attendance & time tracking
      match /attendance/{recordId} {
        allow read: if isCompanyMember(companyId);
        allow create, update: if isCompanyMember(companyId) && request.resource.data.userId == request.auth.uid;
        allow delete: if isCompanyAdmin(companyId);
      }
    }

    // Personal boards (Vision Board, Personal Kanban) - private to user
    match /personalBoards/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;

      match /{document=**} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }
    }

    // Global tasks per user
    match /globalTasks/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;

      match /tasks/{taskId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }
    }
  }
}